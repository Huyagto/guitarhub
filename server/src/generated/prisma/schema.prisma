generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                     Int      @id @default(autoincrement())
  email                  String   @unique
  password               String?
  fullName               String
  phone                  String?
  staffCode              String?  @unique
  googleId               String?  @unique
  defaultShippingAddress Json?
  branchId               Int?
  role                   Role     @default(CUSTOMER)
  isActive               Boolean  @default(true)
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt

  cart          Cart?
  orders        Order[] @relation("CustomerOrders")
  handledOrders Order[] @relation("StaffHandledOrders")
  branch        Branch? @relation("BranchStaff", fields: [branchId], references: [id], onDelete: SetNull)

  @@index([branchId])
  @@map("users")
}

model Branch {
  id        Int          @id @default(autoincrement())
  name      String
  code      String       @unique
  address   String?
  phone     String?
  latitude  Float?
  longitude Float?
  status    BranchStatus @default(ACTIVE)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  staff     User[]            @relation("BranchStaff")
  inventory BranchInventory[]
  orders    Order[]

  @@index([status])
  @@map("branches")
}

model Category {
  id          Int            @id @default(autoincrement())
  name        String         @unique
  slug        String         @unique
  description String?
  image       String?
  status      CategoryStatus @default(ACTIVE)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  products Product[]

  @@map("categories")
}

model Brand {
  id          Int         @id @default(autoincrement())
  name        String      @unique
  slug        String      @unique
  description String?
  logo        String?
  status      BrandStatus @default(ACTIVE)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  products Product[]

  @@map("brands")
}

model Product {
  id               Int           @id @default(autoincrement())
  name             String
  slug             String        @unique
  sku              String        @unique
  categoryId       Int
  brandId          Int
  price            Decimal       @db.Decimal(10, 2)
  stock            Int           @default(0)
  minStock         Int           @default(5)
  maxStock         Int           @default(20)
  lastRestockedAt  DateTime      @default(now())
  image            String?
  shortDescription String?
  description      String?
  status           ProductStatus @default(DRAFT)
  rating           Decimal       @default(0) @db.Decimal(3, 2)
  reviewCount      Int           @default(0)
  isBestSeller     Boolean       @default(false)
  isNewArrival     Boolean       @default(false)
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  category        Category          @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  brand           Brand             @relation(fields: [brandId], references: [id], onDelete: Restrict)
  cartItems       CartItem[]
  orderItems      OrderItem[]
  branchInventory BranchInventory[]

  @@index([categoryId])
  @@index([brandId])
  @@index([status])
  @@map("products")
}

model BranchInventory {
  id              Int      @id @default(autoincrement())
  branchId        Int
  productId       Int
  stock           Int      @default(0)
  minStock        Int      @default(5)
  maxStock        Int      @default(20)
  lastRestockedAt DateTime @default(now())
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  branch  Branch  @relation(fields: [branchId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([branchId, productId])
  @@index([branchId])
  @@index([productId])
  @@map("branch_inventory")
}

model Voucher {
  id          Int           @id @default(autoincrement())
  code        String        @unique
  type        VoucherType
  value       Decimal       @db.Decimal(10, 2)
  minPurchase Decimal       @default(0) @db.Decimal(10, 2)
  usageLimit  Int           @default(0)
  usedCount   Int           @default(0)
  status      VoucherStatus @default(ACTIVE)
  expiresAt   DateTime
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@index([status])
  @@index([expiresAt])
  @@map("vouchers")
}

model Cart {
  id        Int      @id @default(autoincrement())
  userId    Int      @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user  User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  items CartItem[]

  @@map("carts")
}

model CartItem {
  id        Int      @id @default(autoincrement())
  cartId    Int
  productId Int
  quantity  Int
  unitPrice Decimal  @db.Decimal(10, 2)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  cart    Cart    @relation(fields: [cartId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Restrict)

  @@unique([cartId, productId])
  @@index([productId])
  @@map("cart_items")
}

model Order {
  id               Int                @id @default(autoincrement())
  orderNumber      String             @unique
  customerId       Int?
  customerName     String
  customerEmail    String?
  customerPhone    String?
  shippingInfo     Json
  paymentMethod    OrderPaymentMethod
  paymentStatus    OrderPaymentStatus @default(PENDING)
  status           OrderStatus        @default(PENDING_CONFIRMATION)
  subtotal         Decimal            @db.Decimal(10, 2)
  shippingFee      Decimal            @db.Decimal(10, 2)
  total            Decimal            @db.Decimal(10, 2)
  note             String?
  handledByStaffId Int?
  branchId         Int?
  handledAt        DateTime?
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt

  customer       User?       @relation("CustomerOrders", fields: [customerId], references: [id], onDelete: SetNull)
  handledByStaff User?       @relation("StaffHandledOrders", fields: [handledByStaffId], references: [id], onDelete: SetNull)
  branch         Branch?     @relation(fields: [branchId], references: [id], onDelete: SetNull)
  items          OrderItem[]

  @@index([customerId])
  @@index([handledByStaffId])
  @@index([branchId])
  @@index([status])
  @@index([paymentStatus])
  @@map("orders")
}

model OrderItem {
  id          Int      @id @default(autoincrement())
  orderId     Int
  productId   Int
  productName String
  productSku  String
  image       String?
  quantity    Int
  unitPrice   Decimal  @db.Decimal(10, 2)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  order   Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Restrict)

  @@index([orderId])
  @@index([productId])
  @@map("order_items")
}

enum Role {
  CUSTOMER
  STAFF
  MANAGER
}

enum CategoryStatus {
  ACTIVE
  INACTIVE
}

enum BrandStatus {
  ACTIVE
  INACTIVE
}

enum BranchStatus {
  ACTIVE
  INACTIVE
}

enum ProductStatus {
  ACTIVE
  DRAFT
  ARCHIVED
}

enum OrderStatus {
  AWAITING_PAYMENT
  PENDING_CONFIRMATION
  CONFIRMED
  PREPARING
  READY_TO_SHIP
  SHIPPING
  DELIVERED
  CANCELLED
}

enum OrderPaymentStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
}

enum OrderPaymentMethod {
  COD
  VNPAY
  MOMO
  ZALOPAY
  CASH
  BANK_TRANSFER
}

enum VoucherType {
  PERCENTAGE
  FIXED
}

enum VoucherStatus {
  ACTIVE
  EXPIRED
  DISABLED
}
