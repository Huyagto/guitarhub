{
    "name": "guitarhub-server",
    "version": "1.0.0",
    "description": "GuitarHub backend API",
    "main": "server.js",
    "scripts": {
        "dev": "nodemon server.js",
        "start": "node server.js",
        "db:generate": "prisma generate --schema=src/prisma/schema.prisma",
        "db:migrate": "prisma migrate dev --schema=src/prisma/schema.prisma",
        "db:studio": "prisma studio --schema=src/prisma/schema.prisma",
        "db:seed": "node src/prisma/seed.js"
    },
    "prisma": {
        "schema": "src/prisma/schema.prisma"
    },
    "dependencies": {
        "@prisma/client": "^5.22.0",
        "bcryptjs": "^2.4.3",
        "cookie-parser": "^1.4.7",
        "cors": "^2.8.5",
        "dotenv": "^16.4.5",
        "express": "^4.21.2",
        "express-validator": "^7.2.1",
        "googleapis": "^171.4.0",
        "ioredis": "^5.10.1",
        "jsonwebtoken": "^9.0.2",
        "nodemailer": "^8.0.5",
        "socket.io": "^4.8.3"
    },
    "devDependencies": {
        "nodemon": "^3.1.9",
        "prisma": "^5.22.0"
    }
}
